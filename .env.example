APP_ADDR=:8080
CACHE_MAX_ITEMS=1000

# mock: built-in demo provider
# cloud: POST frames to CLOUD_VISION_ENDPOINT and use the returned objects
# openai: send frames to OpenAI vision and parse object labels
VISION_PROVIDER=mock
CLOUD_VISION_ENDPOINT=
CLOUD_VISION_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-5.5
